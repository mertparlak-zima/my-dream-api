NODE_ENV=development
DEV_AUTH_ENABLED=true
TEST_DATABASE_URL=postgres://mydream:mydream@localhost:5433/mydream
# DATABASE_URL is optional in local development when TEST_DATABASE_URL is set.
# Better Auth secret (>=32 chars) so the auth instance can initialize in tests.
BETTER_AUTH_SECRET=test-secret-change-me-0123456789abcdef
BETTER_AUTH_URL=http://localhost:3000
SENTRY_DSN=
SENTRY_ENVIRONMENT=test
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SEED_MODE=local
