NODE_ENV=development
DEV_AUTH_ENABLED=true
TEST_DATABASE_URL=postgres://mydream:mydream@localhost:5433/mydream
# Supabase pooler URLs are supported by the app/test client because postgres-js prepared statements are disabled.
# DATABASE_URL is optional in local development when TEST_DATABASE_URL is set.
JWT_SECRET=dev-jwt-secret-change-me
SUPABASE_URL=
SENTRY_DSN=
SENTRY_ENVIRONMENT=test
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
SEED_MODE=local
