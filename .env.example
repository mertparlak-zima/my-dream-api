# Local Postgres (Docker Compose):
DATABASE_URL=postgres://mydream:mydream@localhost:5433/mydream
# Production: self-hosted PostgreSQL (Hetzner/Coolify) direct connection URL.
# DATABASE_URL=postgres://<user>:<pass>@<host>:5432/<db>
# Redis (cache / rate-limit / idempotency / counters). Today the rate limiter
# falls back to a single-instance in-memory window if Redis is down; hardening to
# Redis-only fail-loud (5xx) is tracked in #65. Use rediss:// for TLS in prod.
REDIS_URL=redis://localhost:6379
# Set to true to bypass the Redis read-through cache while keeping Redis up
# (rate-limit / idempotency still use it). Handy for local debugging.
CACHE_DISABLED=false
OPENROUTER_API_KEY=

# Better Auth (identity). SECRET must be >=32 chars; generate: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-secret-change-me-0123456789abcdef
BETTER_AUTH_URL=http://localhost:3000

# Social providers. Required in production; optional locally (a provider is
# registered only when its full set is present, so local can run with none and
# use email/password + X-Dev-User-Id). NEVER commit real secrets.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
APPLE_SERVICE_ID=
APPLE_APP_BUNDLE_IDENTIFIER=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# PEM contents; escape newlines as \n if storing on a single line.
APPLE_PRIVATE_KEY=

CORS_ALLOWED_ORIGINS=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1
PORT=3000
NODE_ENV=development
DEV_AUTH_ENABLED=true
SEED_MODE=local

# Structured logger (#61). Defaults: level debug(dev)/info(prod),
# format pretty(dev)/json(prod), enabled true (set false to silence, e.g. tests).
LOG_LEVEL=
LOG_FORMAT=
LOG_ENABLED=
