# Local Postgres:
DATABASE_URL=postgres://mydream:mydream@localhost:5433/mydream
# Production/Supabase:
# DATABASE_URL=<supabase-transaction-pooler-or-direct-postgres-url>
JWT_SECRET=dev-jwt-secret-change-me
OPENROUTER_API_KEY=
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
CORS_ALLOWED_ORIGINS=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1
PORT=3000
NODE_ENV=development
DEV_AUTH_ENABLED=true
SEED_MODE=local

# Supabase config push secrets. Keep real values in .env or CI secrets only.
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
