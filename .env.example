# Local Postgres:
DATABASE_URL=postgres://mydream:mydream@localhost:5433/mydream
# Production/Supabase:
# DATABASE_URL=<supabase-transaction-pooler-or-direct-postgres-url>
# Redis (cache / rate-limit / idempotency / counters). Optional locally; when
# unset, Redis-backed features degrade gracefully. Use rediss:// for TLS in prod.
REDIS_URL=redis://localhost:6379
# Set to true to bypass the Redis read-through cache while keeping Redis up
# (rate-limit / idempotency still use it). Handy for local debugging.
CACHE_DISABLED=false
JWT_SECRET=dev-jwt-secret-change-me
OPENROUTER_API_KEY=
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_ISSUER=
CORS_ALLOWED_ORIGINS=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1
PORT=3000
NODE_ENV=development
DEV_AUTH_ENABLED=true
SEED_MODE=local

# Structured logger (#61). Defaults: level debug(dev)/info(prod),
# format pretty(dev)/json(prod), enabled true (set false to silence, e.g. tests).
LOG_LEVEL=
LOG_FORMAT=
LOG_ENABLED=

# Supabase config push secrets. Keep real values in .env or CI secrets only.
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
